{
    "commit-msg": {
        "enabled": true,
        "actions": []
    },
    "pre-push": {
        "enabled": false,
        "actions": []
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "php -l $(git diff --cached --name-only --diff-filter=ACM | grep '.php$')",
                "options": [],
                "description": "Verificando sintaxe PHP..."
            },
            {
                "action": "./vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --path-mode=intersection --quiet $(git diff --cached --name-only --diff-filter=ACM | grep '.php$')",
                "options": [],
                "description": "Corrigindo estilo de código..."
            }
        ]
    },
    "prepare-commit-msg": {
        "enabled": false,
        "actions": []
    }
}