{
    "commit-msg": {
        "enabled": true,
        "actions": []
    },
    "pre-push": {
        "enabled": false,
        "actions": []
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\PHP\\Action\\Linting",
                "options": {
                    "php": "php"
                }
            },
            {
                "action": "\\Dev\\GitHooks\\PhpCsFixerAction",
                "options": {
                    "binary": "vendor/bin/php-cs-fixer",
                    "config": ".php-cs-fixer.php",
                    "auto_fix": false
                }
            }
        ]
    },
    "prepare-commit-msg": {
        "enabled": false,
        "actions": []
    }
}